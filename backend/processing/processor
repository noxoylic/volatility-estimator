from dataclasses import dataclass
from typing import Optional
import numpy as np
from scipy.stats import iqr


@dataclass
class MarketMetadata:
    """
    STATIC DATA: Fetched once per session.
    Represents the Event Contract details (Question, Slug, etc.).
    """
    token_id: str
    condition_id: str
    question: str
    slug: str
    description: Optional[str] = None

class Tick:
    """
    DYNAMIC DATA: The 'Atomic Unit' of the RN-JD Model.
    FLAT structure for zero-overhead conversion to Numpy arrays.
    """
    __slots__ = [
        'timestamp', 'token_id', 
        'best_bid', 'best_ask', 'spread', 
        'depth_bid', 'depth_ask',
        'canonical_p', 'logit_x', 'noise_var'
    ]

    def __init__(self, timestamp, token_id, best_bid, best_ask, depth_bid, depth_ask, 
                 spread, canonical_p, logit_x, noise_var):
        self.timestamp = timestamp
        self.token_id = token_id
        
        # Raw Data (Microstructure)
        self.best_bid = best_bid
        self.best_ask = best_ask
        self.depth_bid = depth_bid
        self.depth_ask = depth_ask
        self.spread = spread
        
        # RN-JD Model Inputs (Section 5.1 of Paper)
        self.canonical_p = canonical_p  # p_t (Canonical Mid)
        self.logit_x = logit_x          # x_t (Log-Odds)
        self.noise_var = noise_var      # sigma_eta^2 (Microstructure Noise)




def compute_canonical_mid(bids: np.ndarray, asks: np.ndarray, 
                         volumes: np.ndarray, window_size: int = 10) -> float:
    """
    Trade-weighted canonical mid computation.
    
    Premise (Paper Section 5.1):
    - Trade-weighted mid reduces microstructure bias vs. simple bid-ask midpoint
    - Weights monotone in trade size and inverse spread
    - De-bounces bid-ask flicker by weighting recent observations
    
    Args:
        bids: Array of bid prices in sliding window
        asks: Array of ask prices in sliding window
        volumes: Array of trade volumes (proxy for importance)
        window_size: Number of recent observations to consider
    
    Returns:
        p_tilde: Canonical mid price (trade-weighted)
    
    Implementation:
        p_tilde_t = (1/Z_t) * Σ w_u * (b_u + a_u)/2
        where w_u = volume_u / spread_u (weight high volume, tight spreads)
    """
    
    # most recent observations
    bids = bids[-window_size:]
    asks = asks[-window_size:]
    volumes = volumes[-window_size:]
    
    # Compute simple mids
    mids = (bids + asks) / 2.0
    
    # Compute spreads
    spreads = asks - bids
    spreads = np.maximum(spreads, 1e-6)  # Avoid division by zero
    
    # Weight by volume / spread (prioritize tight, liquid markets)
    weights = volumes / spreads
    
    # Normalize weights
    Z_t = np.sum(weights)
    if Z_t < 1e-10:
        # Fallback to simple average if no valid weights
        return np.mean(mids)
    
    weights_normalized = weights / Z_t
    
    # Compute weighted canonical mid
    p_tilde = np.sum(weights_normalized * mids)
    
    return p_tilde


def clip_and_resample(prices: np.ndarray, timestamps: np.ndarray,
                     epsilon: float = 1e-5, target_freq_hz: float = 1.0) -> Tuple[np.ndarray, np.ndarray]:
    """
    Clip extreme probabilities and resample to uniform grid.
    
    Premise (Paper Section 5.1):
    - Extreme probabilities cause logit explosion
    - Uniform grid enables causal forecasting and filtering
    - LOCF (Last Observation Carried Forward) between resamples
    
    Args:
        prices: Array of canonical mid prices p_tilde
        timestamps: Unix timestamps (seconds)
        epsilon: Clipping boundary (default 1e-5)
        target_freq_hz: Target sampling frequency in Hz (default 1 Hz)
    
    Returns:
        prices_clipped: Clipped prices in [epsilon, 1-epsilon]
        timestamps_uniform: Uniform grid timestamps
    
    Implementation:
        1. Clamp to [ε, 1-ε]
        2. Create uniform time grid
        3. Resample via LOCF
    """
    # Clip to bounded domain
    prices_clipped = np.clip(prices, epsilon, 1.0 - epsilon)
    
    # Create uniform time grid
    t_start = timestamps[0]
    t_end = timestamps[-1]
    dt = 1.0 / target_freq_hz  # Time step in seconds
    
    timestamps_uniform = np.arange(t_start, t_end, dt)
    
    # Resample using LOCF (Last Observation Carried Forward)
    prices_resampled = np.zeros(len(timestamps_uniform))
    
    j = 0  # Index for original data
    for i, t_grid in enumerate(timestamps_uniform):
        # Find last observation before or at t_grid
        while j < len(timestamps) - 1 and timestamps[j + 1] <= t_grid:
            j += 1
        prices_resampled[i] = prices_clipped[j]
    
    return prices_resampled, timestamps_uniform


def remove_outliers(bids: np.ndarray, asks: np.ndarray, 
                   prices: np.ndarray, timestamps: np.ndarray,
                   tick_size: float = 0.001) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Remove crossed/locked markets and isolated price spikes.
    
    Premise (Paper Section 5.1):
    - Crossed/locked books (bid >= ask) corrupt latent signal
    - Isolated spikes that revert within 1 tick are microstructure noise
    - Trading halts should be excluded
    
    Args:
        bids: Best bid prices
        asks: Best ask prices
        prices: Canonical mid prices
        timestamps: Unix timestamps
        tick_size: Minimum meaningful price movement
    
    Returns:
        prices_clean: Cleaned price series
        timestamps_clean: Corresponding timestamps
        valid_mask: Boolean mask of valid observations
    
    Implementation:
        1. Remove bid >= ask (crossed/locked)
        2. Remove spikes that revert within 1 update and 1 tick
    """
    n = len(prices)
    valid_mask = np.ones(n, dtype=bool)
    
    # Remove crossed or locked markets (bid >= ask)
    crossed_mask = bids >= asks
    valid_mask &= ~crossed_mask
    
    # Remove isolated spikes
    # A spike is: |p[i] - p[i-1]| > tick AND |p[i+1] - p[i-1]| <= tick
    # (i.e., price jumps then immediately reverts)
    for i in range(1, n - 1):
        if not valid_mask[i]:
            continue
            
        prev_diff = abs(prices[i] - prices[i - 1])
        next_diff = abs(prices[i + 1] - prices[i - 1])
        
        # If current point is far from previous, but next point reverts
        if prev_diff > tick_size and next_diff <= tick_size:
            valid_mask[i] = False
    
    # Apply mask
    prices_clean = prices[valid_mask]
    timestamps_clean = timestamps[valid_mask]
    
    return prices_clean, timestamps_clean, valid_mask


def estimate_noise_variance(spreads: np.ndarray, depths: np.ndarray,
                           trade_rates: np.ndarray, imbalances: np.ndarray,
                           innovations: np.ndarray,
                           bounds: Tuple[float, float] = (1e-6, 1.0)) -> np.ndarray:
    """
    Heteroskedastic microstructure noise variance model.
    
    Premise (Paper Section 5.1):
    - Microstructure noise is state-dependent
    - Tighter spreads → lower noise variance
    - Model: σ²_η(t) = a₀ + a₁s²_t + a₂d_t⁻¹ + a₃r_t + a₄ι²_t
    
    Args:
        spreads: Bid-ask spreads s_t
        depths: Market depth d_t (total size at best bid/ask)
        trade_rates: Trading intensity r_t (trades per second)
        imbalances: Order imbalance ι_t = (bid_depth - ask_depth) / total_depth
        innovations: Short-horizon squared price innovations (for calibration)
        bounds: (min, max) variance bounds for clipping
    
    Returns:
        sigma_eta_sq: Time-varying measurement noise variance σ²_η(t)
    
    Implementation:
        1. Robust regression: innovations ~ f(spread, depth, rate, imbalance)
        2. Clip to reasonable bounds
    """
    
    # Construct feature matrix X
    n = len(spreads)
    X = np.column_stack([
        np.ones(n),                    # Intercept a₀
        spreads ** 2,                  # a₁ * s²
        1.0 / (depths + 1e-6),        # a₂ / d (avoid div by zero)
        trade_rates,                   # a₃ * r
        imbalances ** 2                # a₄ * ι²
    ])
    
    # Robust regression using Huber loss (downweight outliers)
    # Simple implementation: use median absolute deviation scaling
    y = innovations  # Squared innovations as proxy for noise variance
    
    # Remove NaN/Inf
    valid = np.isfinite(X).all(axis=1) & np.isfinite(y)
    X_valid = X[valid]
    y_valid = y[valid]
    
    if len(y_valid) < 5:
        # Fallback to constant variance if insufficient data
        return np.full(n, np.median(y_valid) if len(y_valid) > 0 else 0.01)
    
    # Ordinary least squares (paper suggests robust regression, but OLS is reasonable start)
    # For production: use scipy.stats.siegelslopes or robust M-estimator
    try:
        coeffs = np.linalg.lstsq(X_valid, y_valid, rcond=None)[0]
    except np.linalg.LinAlgError:
        # Fallback to constant variance
        return np.full(n, np.median(y_valid))
    
    # Predict noise variance
    sigma_eta_sq = X @ coeffs
    
    # Clip to bounds
    sigma_eta_sq = np.clip(sigma_eta_sq, bounds[0], bounds[1])
    
    return sigma_eta_sq


def compute_short_horizon_innovations(prices: np.ndarray, 
                                     horizon: int = 5) -> np.ndarray:
    """
    Compute squared price innovations for noise variance calibration.
    
    Args:
        prices: Price series (already in logit space or raw)
        horizon: Number of steps for differencing
    
    Returns:
        innovations_sq: Squared innovations (Δp)²
    """
    if len(prices) < horizon + 1:
        return np.array([])
    
    # Compute differences
    diffs = np.diff(prices, n=1)
    
    # Square innovations
    innovations_sq = diffs ** 2
    
    # Pad to match original length
    innovations_sq = np.concatenate([np.full(1, np.nan), innovations_sq])
    
    return innovations_sq